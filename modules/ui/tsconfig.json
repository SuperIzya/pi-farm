{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "strict": true,
    "module": "NodeNext",
    "target": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "jsx": "react",
    "sourceMap": true,
    "plugins": [{ "name": "typescript-plugin-css-modules", "options": { "customMatcher": "\\.s?css$" } }]
  },
  "include": [
    "**/*.tsx",
    "**/*.ts",
    "**/*.d.ts"
  ]
}
