{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "strict": true,
    "module": "NodeNext",
    "target": "ESNext",
    "allowJs": true,
    "jsx": "react",
    "sourceMap": true,
    "plugins": [{
      "name": "typescript-plugin-css-modules",
      "options": {
        "customMatcher": "\\.s?css$"
      }
    }]
  },
  "files": ["src/index.tsx", "declarations.d.ts"],
  "include": [
    "**/*.tsx",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
